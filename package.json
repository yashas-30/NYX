{
  "name": "nyx",
  "productName": "NYX",
  "private": true,
  "version": "3.0.0",
  "author": "NYX Dev Team",
  "description": "NYX is a premium, high-fidelity AI coding environment and runner that executes powerful local models on your GPU and orchestrates cloud LLMs, featuring persistent semantic memory, silent reasoning traces, local Vulkan GPU acceleration, live web search grounding, and a beautifully crafted interface.",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "turbo run dev",
    "dev:desktop": "tauri dev",
    "dev:web": "pnpm --filter @nyx/web dev",
    "build": "turbo run build",
    "build:server": "pnpm --filter @nyx/server build",
    "build:web": "pnpm --filter @nyx/web build",
    "tauri": "tauri",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && node -e \"const fs = require('fs'); fs.rmSync('node_modules', { recursive: true, force: true })\"",
    "prepare": "husky",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.8",
    "concurrently": "^10.0.3",
    "happy-dom": "^20.10.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "snyk": "^1.1305.1",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "turbo": "^2.9.18",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  }
}
