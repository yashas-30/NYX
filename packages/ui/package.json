{
  "name": "@nyx/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./components/*": {
      "import": "./src/components/*.tsx"
    },
    "./tokens/*": {
      "import": "./src/tokens/*.ts"
    }
  },
  "scripts": {
    "lint": "eslint src",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@nyx/config": "workspace:*",
    "typescript": "~6.0.3"
  }
}
