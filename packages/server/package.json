    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^6.1.0",
    "http-proxy-middleware": "^4.1.1",
    "keytar": "^7.9.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rotating-file-stream": "^3.2.9",
    "zod": "^3.23.8"
