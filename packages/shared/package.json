{
  "name": "@nyx/shared",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "build:dev": "tsup src/index.ts --format cjs,esm --no-dts",
    "dev": "tsup src/index.ts --format cjs,esm --no-dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nyx/config": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "~5.8.2"
  }
}
