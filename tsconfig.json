{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "noEmit": true
  },
  "files": [],
  "exclude": ["node_modules", "dist", "scratch", ".nyx-cache", ".nyx-models"],
  "include": [],
  "references": [
    { "path": "./apps/web" },
    { "path": "./packages/shared" }
  ],
  "watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "**/dist",
      "**/scratch",
      "**/.nyx-cache",
      "**/.nyx-models"
    ],
    "excludeFiles": ["**/server.log", "**/server.err"]
  }
}