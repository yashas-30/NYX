{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@nyx/server#dev": {
      "dependsOn": ["@nyx/shared#build"],
      "cache": false,
      "persistent": true
    },
    "@nyx/web#dev": {
      "dependsOn": ["@nyx/shared#build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "clean": {
      "cache": false
    }
  }
}