{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@nyx/shared#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@nyx/shared#dev": {
      "dependsOn": ["@nyx/shared#build"],
      "cache": false,
      "persistent": true
    }
  }
}