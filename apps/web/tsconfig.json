{
  "extends": "@nyx/config/tsconfig.react.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@src/*": ["./src/*"],
      "@nyx/shared/*": ["../../packages/shared/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@features/*": ["./src/features/*"],
      "@core/*": ["./src/core/*"],
      "@assets/*": ["./src/assets/*"],
      "~types/*": ["./src/types/*"],
      "~components/*": ["./src/components/*"],
      "~features/*": ["./src/features/*"],
      "@server/*": ["./server/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["src/graphify-out", "node_modules", "dist"]
}