{
  "extends": "@nyx/config/tsconfig.node.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@server/*": ["./server/*"]
    },
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["server.ts", "server/**/*", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}