# NYX Environment Configuration Template
# Copy this file to .env and configure the variables accordingly.

# --- Runtime Environment ---
# Allowed values: development, production, test
NODE_ENV=development

# --- Server Ports & URLs ---
PORT=3000
SCRAPLING_PORT=3001
ANTIGRAVITY_PORT=3002
LLAMA_PORT=11434
LMSTUDIO_PORT=1234
ANTIGRAVITY_URL=http://localhost:3002
ALLOWED_ORIGINS=http://localhost:5173

# --- Security & Keys ---
# CRITICAL: In production, NYX_MASTER_KEY must be a cryptographically secure key of at least 32 characters.
# In development, it defaults to a dynamically generated warning key if left empty.
NYX_MASTER_KEY=placeholder_32_characters_minimum_key_length

# Allow the server to execute arbitrary shell commands (security sensitive)
NYX_ALLOW_RAW_TERMINAL=false

# Require requests to be signed using a shared secret
ENFORCE_REQUEST_SIGNATURE=false

# Key used for administrative operations
ADMIN_KEY=your_admin_secret_key

# --- External AI Providers ---
GEMINI_API_KEY=your_gemini_api_key
LLM_API_KEY=your_llm_api_key

# --- Third-Party Integrations ---
# Dialogflow (Google Cloud AI)
DIALOGFLOW_PROJECT_ID=your_dialogflow_project_id
DIALOGFLOW_ACCESS_TOKEN=your_dialogflow_access_token

# Rasa (Open source conversational AI)
RASA_URL=http://localhost:5005

# Antigravity API
ANTIGRAVITY_API_KEY=your_antigravity_api_key

# --- System Paths ---
NYX_WORKSPACE_ROOT=
NYX_PYTHON_PATH=
PLUGINS_DIR=
IS_PACKAGED=false

# --- Logging & Monitoring ---
LOG_LEVEL=info
SENTRY_DSN=
OTLP_TRACE_ENDPOINT=

# --- Services (Queue, Cache, Database) ---
RABBITMQ_URL=amqp://localhost
REDIS_HOST=localhost
REDIS_PORT=6379
RULES_DB_MAX_ENTRIES=500
MAX_TOKEN_QUOTA=

# --- Cloudflare Gateway Integration ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_GATEWAY_NAME=
USE_CLOUDFLARE_GATEWAY=false

# --- Webhook & Alerting Channels ---
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
