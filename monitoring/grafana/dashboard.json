{
  "title": "NYX AI Platform Dashboard",
  "uid": "nyx-platform-001",
  "panels": [
    {
      "title": "Total Requests",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(nyx_requests_total[5m])) by (provider, model)", "legendFormat": "{{provider}} - {{model}}" }
      ]
    },
    {
      "title": "Inference Latency (p95)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(nyx_inference_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95 Latency" }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "targets": [
        { "expr": "avg(nyx_cache_hit_ratio)", "legendFormat": "Global Hit Rate" }
      ]
    }
  ]
}
